<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>

<style>
  body { background: #f0f2f5; }
  .shift-card {
    border: none;
    border-radius: 14px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.08);
    transition: transform 0.15s;
  }
  .shift-card:hover { transform: translateY(-2px); }
  .shift-active  { border-left: 4px solid #1a73e8 !important; }
  .shift-removed { border-left: 4px solid #dc3545 !important; opacity: 0.6; }
  .shift-future  { border-left: 4px solid #dee2e6 !important; }
  .time-badge {
    background: #e8f0fe;
    color: #1a73e8;
    border-radius: 20px;
    font-size: 0.78rem;
    padding: 0.3em 0.9em;
    font-weight: 500;
  }
  .day-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.8px; }
</style>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-8">

      <div class="d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-calendar-week fs-4 text-primary"></i>
        <div>
          <h4 class="mb-0 fw-semibold">My Schedule</h4>
          <small class="text-muted">Default shift: 8:00 AM – 4:00 PM</small>
        </div>
      </div>

      <div class="d-flex flex-column gap-3">
        <% 
          const dayNames = ["Monday","Tuesday","Wednesday","Thursday","Friday"];
          weekDays.forEach(function(d, i) {
            const dateStr  = d.toISOString().split("T")[0];
            const isRemoved = removedDays.includes(dateStr);
            const isToday   = dateStr === new Date().toISOString().split("T")[0];
        %>
          <div class="card shift-card p-3 <%= isRemoved ? 'shift-removed' : isToday ? 'shift-active' : 'shift-future' %>">
            <div class="d-flex align-items-center justify-content-between">
              <div>
                <div class="day-label text-muted mb-1"><%= dayNames[i] %></div>
                <div class="fw-semibold text-dark"><%= d.toDateString() %></div>
                <% if (!isRemoved) { %>
                  <span class="time-badge mt-2 d-inline-block">
                    <i class="bi bi-clock me-1"></i>8:00 AM – 4:00 PM
                  </span>
                <% } %>
              </div>
              <div class="text-end">
                <% if (isRemoved) { %>
                  <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-2">
                    <i class="bi bi-x-circle me-1"></i>Day Off Approved
                  </span>
                <% } else if (isToday) { %>
                  <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2">
                    <i class="bi bi-star-fill me-1"></i>Today
                  </span>
                <% } else { %>
                  <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3 py-2">
                    <i class="bi bi-calendar-check me-1"></i>Scheduled
                  </span>
                <% } %>
              </div>
            </div>
          </div>
        <% }); %>
      </div>

    </div>
  </div>
</div>