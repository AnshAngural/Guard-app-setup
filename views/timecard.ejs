<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>

<style>
  body { background: #f0f2f5; }
  .card {
    border: none;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }
  .card-header-blue {
    background: linear-gradient(135deg, #1a73e8, #0d47a1);
    border-radius: 16px 16px 0 0;
    padding: 1.5rem;
  }
  .timer-display {
    font-size: 3rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: #1a73e8;
    letter-spacing: 2px;
  }
  .btn-clock {
    border-radius: 12px;
    padding: 0.7rem 2rem;
    font-weight: 500;
    border: none;
    transition: opacity 0.2s, transform 0.1s;
  }
  .btn-clock:hover { opacity: 0.9; transform: translateY(-1px); }
  .table th {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: #6c757d;
    font-weight: 600;
  }
  .table td { vertical-align: middle; font-size: 0.9rem; }
  .hours-pill {
    background: #e8f0fe;
    color: #1a73e8;
    border-radius: 20px;
    padding: 0.25em 0.85em;
    font-size: 0.82rem;
    font-weight: 500;
  }
  .end-time-note {
    background: #fff3cd;
    border-radius: 10px;
    font-size: 0.82rem;
    padding: 0.5rem 1rem;
    color: #856404;
  }
</style>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">

      <!-- Clock Card -->
      <div class="card mb-4">
        <div class="card-header-blue text-white">
          <div class="d-flex align-items-center gap-2">
            <i class="bi bi-stopwatch fs-5"></i>
            <div>
              <h5 class="mb-0 fw-semibold">Timecard</h5>
              <small class="opacity-75">Shift ends at 4:00 PM</small>
            </div>
          </div>
        </div>

        <div class="card-body p-4 text-center">

          <!-- Timer -->
          <div class="timer-display mb-1" id="timer">00:00:00</div>
          <div class="text-muted small mb-3" id="timer-label">
            <% if (record && record.clockIn && !record.clockOut) { %>
              Elapsed since clock-in
            <% } else if (record && record.clockOut) { %>
              Shift complete
            <% } else { %>
              Not clocked in
            <% } %>
          </div>

          <!-- End time warning -->
          <% if (record && record.clockIn && !record.clockOut) { %>
            <div class="end-time-note mb-4 mx-auto" style="max-width:280px">
              <i class="bi bi-clock-history me-1"></i>
              Schedule ends at <strong>4:00 PM</strong> today
            </div>
          <% } %>

          <!-- Buttons -->
          <div class="d-flex justify-content-center gap-3">
            <% if (!record || (!record.clockIn)) { %>
              <form action="/clockin" method="POST">
                <button class="btn btn-success btn-clock">
                  <i class="bi bi-play-fill me-2"></i>Clock In
                </button>
              </form>
            <% } else if (record.clockIn && !record.clockOut) { %>
              <form action="/clockout" method="POST">
                <button class="btn btn-danger btn-clock">
                  <i class="bi bi-stop-fill me-2"></i>Clock Out
                </button>
              </form>
            <% } else { %>
              <div class="alert alert-success rounded-3 px-4 py-2 mb-0">
                <i class="bi bi-check-circle-fill me-2"></i>
                Shift complete — <strong><%= record.hoursWorked %> hrs</strong> logged
              </div>
            <% } %>
          </div>

          <!-- Clock in time display -->
          <% if (record && record.clockIn) { %>
            <div class="mt-3 text-muted small">
              Clocked in at <strong><%= new Date(record.clockIn).toLocaleTimeString() %></strong>
              <% if (record.clockOut) { %>
                &nbsp;→&nbsp; Out at <strong><%= new Date(record.clockOut).toLocaleTimeString() %></strong>
              <% } %>
            </div>
          <% } %>

        </div>
      </div>

      <!-- History Card -->
      <div class="card">
        <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between px-4 py-3" style="border-radius:16px 16px 0 0">
          <div class="d-flex align-items-center gap-2">
            <i class="bi bi-journal-text text-primary"></i>
            <h6 class="mb-0 fw-semibold">Recent Timecards</h6>
          </div>
          <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill">Last 14 days</span>
        </div>

        <div class="card-body p-0">
          <% if (history.length === 0) { %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-inbox fs-2 d-block mb-2"></i>
              <small>No completed shifts yet</small>
            </div>
          <% } else { %>
            <div class="table-responsive">
              <table class="table mb-0">
                <thead>
                  <tr>
                    <th class="ps-4">Date</th>
                    <th>Clock In</th>
                    <th>Clock Out</th>
                    <th class="pe-4 text-end">Hours</th>
                  </tr>
                </thead>
                <tbody>
                  <% history.forEach(h => { %>
                    <tr>
                      <td class="ps-4"><%= h.date %></td>
                      <td><%= new Date(h.clockIn).toLocaleTimeString() %></td>
                      <td><%= new Date(h.clockOut).toLocaleTimeString() %></td>
                      <td class="pe-4 text-end">
                        <span class="hours-pill"><%= h.hoursWorked %> hrs</span>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Live timer script -->
<script>
  <% if (record && record.clockIn && !record.clockOut) { %>
    const clockInTime = new Date("<%= record.clockIn.toISOString() %>");
    const endOfShift  = new Date(clockInTime);
    endOfShift.setHours(16, 0, 0, 0); // 4:00 PM

    function updateTimer() {
      const now     = new Date();
      const elapsed = Math.floor((now - clockInTime) / 1000);
      const h = String(Math.floor(elapsed / 3600)).padStart(2, "0");
      const m = String(Math.floor((elapsed % 3600) / 60)).padStart(2, "0");
      const s = String(elapsed % 60).padStart(2, "0");
      document.getElementById("timer").textContent = `${h}:${m}:${s}`;

      // Flash red when past 4pm
      if (now > endOfShift) {
        document.getElementById("timer").style.color = "#dc3545";
        document.getElementById("timer-label").textContent = "⚠ Past scheduled end time";
      }
    }

    updateTimer();
    setInterval(updateTimer, 1000);
  <% } else if (record && record.clockOut) { %>
    const ms = new Date("<%= record.clockOut.toISOString() %>") - new Date("<%= record.clockIn.toISOString() %>");
    const totalSecs = Math.floor(ms / 1000);
    const h = String(Math.floor(totalSecs / 3600)).padStart(2, "0");
    const m = String(Math.floor((totalSecs % 3600) / 60)).padStart(2, "0");
    const s = String(totalSecs % 60).padStart(2, "0");
    document.getElementById("timer").textContent = `${h}:${m}:${s}`;
    document.getElementById("timer").style.color = "#198754";
  <% } %>
</script>