<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>

<style>
  body { background: #f0f2f5; }
  .page-header {
    background: linear-gradient(135deg, #1a73e8, #0d47a1);
    border-radius: 16px;
    padding: 1.5rem 2rem;
    color: white;
    margin-bottom: 2rem;
  }
  .main-card {
    border: none;
    border-radius: 16px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
  }
  .stat-pill {
    background: rgba(255,255,255,0.15);
    border-radius: 10px;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
  }
  .table th {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: #6c757d;
    font-weight: 600;
    border-bottom: 2px solid #f0f2f5;
    padding: 1rem 1.25rem;
  }
  .table td {
    padding: 1rem 1.25rem;
    vertical-align: middle;
    font-size: 0.9rem;
    border-bottom: 1px solid #f8f9fa;
  }
  .table tbody tr:hover { background: #f8f9fb; }
  .hours-pill {
    background: #e8f0fe;
    color: #1a73e8;
    border-radius: 20px;
    padding: 0.25em 0.85em;
    font-size: 0.82rem;
    font-weight: 500;
  }
</style>

<div class="container py-5">

  <div class="page-header">
    <div class="d-flex align-items-center justify-content-between mb-3">
      <a href="/admin/guards" class="btn btn-light btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Guards
      </a>
      <form action="/admin/guards/<%= guard._id %>/delete"
            method="POST"
            onsubmit="return confirm('Delete <%= guard.name %>? This cannot be undone.')">
        <button class="btn btn-danger btn-sm">
          <i class="bi bi-trash me-1"></i>Delete Account
        </button>
      </form>
    </div>

    <div class="d-flex align-items-center gap-3">
      <div style="width:52px;height:52px;border-radius:14px;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:700;">
        <%= guard.name.charAt(0).toUpperCase() %>
      </div>
      <div>
        <h4 class="mb-0 fw-semibold"><%= guard.name %></h4>
        <small class="opacity-75"><%= guard.email %></small>
      </div>
    </div>

    <div class="d-flex gap-3 mt-3">
      <div class="stat-pill">
        <i class="bi bi-calendar3 me-1"></i>
        <%= timecards.length %> shifts logged
      </div>
      <div class="stat-pill">
        <i class="bi bi-clock me-1"></i>
        <%= totalHours %> total hours
      </div>
    </div>
  </div>

  <div class="main-card card">
    <div class="card-body p-0">

      <% if (timecards.length === 0) { %>
        <div class="text-center py-5 text-muted">
          <i class="bi bi-clock fs-2 d-block mb-2"></i>
          <p class="mb-0">No timecard records found</p>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th class="ps-4">Date</th>
                <th>Clock In</th>
                <th>Clock Out</th>
                <th class="text-end pe-4">Hours Worked</th>
              </tr>
            </thead>
            <tbody>
              <% timecards.forEach(t => { %>
                <tr>
                  <td class="ps-4 fw-medium"><%= t.date %></td>
                  <td>
                    <% if (t.clockIn) { %>
                      <span class="text-success">
                        <i class="bi bi-play-fill me-1"></i>
                        <%= new Date(t.clockIn).toLocaleTimeString() %>
                      </span>
                    <% } else { %>
                      <span class="text-muted">—</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (t.clockOut) { %>
                      <span class="text-danger">
                        <i class="bi bi-stop-fill me-1"></i>
                        <%= new Date(t.clockOut).toLocaleTimeString() %>
                      </span>
                    <% } else { %>
                      <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3">
                        Active
                      </span>
                    <% } %>
                  </td>
                  <td class="text-end pe-4">
                    <% if (t.hoursWorked) { %>
                      <span class="hours-pill"><%= t.hoursWorked %> hrs</span>
                    <% } else { %>
                      <span class="text-muted small">In progress</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

    </div>
  </div>
</div>