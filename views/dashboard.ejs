<h1 class="text-center mb-4">Welcome to Guard Portal 🛡️</h1>

<p class="text-center text-muted mb-5">
    Secure platform for security guards to manage schedules, timecards, and work requests.
</p>

<div class="container">
    <div class="row g-4">

        <div class="col-md-3">
            <a href="/schedule" class="text-decoration-none text-dark">
                <div class="card shadow-sm h-100 text-center clickable-card">
                    <div class="card-body">
                        <h5 class="card-title">📅 My Schedule</h5>
                        <p class="card-text text-muted">
                            View your assigned shifts and duty locations.
                        </p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a href="/timecard" class="text-decoration-none text-dark">
                <div class="card shadow-sm h-100 text-center clickable-card">
                    <div class="card-body">
                        <h5 class="card-title">⏱ Clock In / Clock Out</h5>
                        <p class="card-text text-muted">
                            Track your working hours with a digital timecard.
                        </p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a href="/dayoff" class="text-decoration-none text-dark">
                <div class="card shadow-sm h-100 text-center clickable-card">
                    <div class="card-body">
                        <h5 class="card-title">📝 Day Off Requests</h5>
                        <p class="card-text text-muted">
                            Request leave and manage approvals online.
                        </p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a href="/profile" class="text-decoration-none text-dark">
                <div class="card shadow-sm h-100 text-center clickable-card">
                    <div class="card-body">
                        <h5 class="card-title">🔐 Secure Access</h5>
                        <p class="card-text text-muted">
                            Private account access for each guard.
                        </p>
                    </div>
                </div>
            </a>
        </div>

    </div>
</div>

<% if (!user) { %>
<div class="text-center mt-5">
    <a href="/login" class="btn btn-primary me-2">Login</a>
    <a href="/signup" class="btn btn-outline-primary">Sign Up</a>
</div>
<% } %>