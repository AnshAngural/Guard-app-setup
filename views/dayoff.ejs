<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Day Off Request</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <style>
    body {
      background: #f0f2f5;
      min-height: 100vh;
    }

    .card {
      border: none;
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.10);
    }

    .card-header {
      background: linear-gradient(135deg, #1a73e8, #0d47a1);
      border-radius: 16px 16px 0 0 !important;
      padding: 1.5rem;
    }

    .form-control, .form-select {
      border-radius: 10px;
      border: 1.5px solid #dee2e6;
      padding: 0.65rem 1rem;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-control:focus {
      border-color: #1a73e8;
      box-shadow: 0 0 0 3px rgba(26, 115, 232, 0.15);
    }

    .btn-submit {
      background: linear-gradient(135deg, #1a73e8, #0d47a1);
      border: none;
      border-radius: 10px;
      padding: 0.7rem 2rem;
      font-weight: 500;
      letter-spacing: 0.3px;
      transition: opacity 0.2s, transform 0.1s;
    }

    .btn-submit:hover {
      opacity: 0.92;
      transform: translateY(-1px);
    }

    .status-badge {
      font-size: 0.78rem;
      padding: 0.35em 0.85em;
      border-radius: 20px;
      font-weight: 500;
      letter-spacing: 0.3px;
    }

    .badge-pending  { background: #fff3cd; color: #856404; }
    .badge-approved { background: #d1e7dd; color: #0a5c36; }
    .badge-rejected { background: #f8d7da; color: #842029; }

    .history-card {
      border: none;
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    }

    .history-card .card-header {
      background: #ffffff;
      border-bottom: 1.5px solid #f0f2f5;
      border-radius: 16px 16px 0 0 !important;
      padding: 1.2rem 1.5rem;
    }

    .table th {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      color: #6c757d;
      font-weight: 600;
      border-bottom: 1.5px solid #f0f2f5;
    }

    .table td {
      vertical-align: middle;
      font-size: 0.92rem;
      color: #343a40;
    }

    .table tbody tr {
      border-bottom: 1px solid #f8f9fa;
      transition: background 0.15s;
    }

    .table tbody tr:hover {
      background: #f8f9fb;
    }

    .empty-state {
      padding: 2.5rem 1rem;
      color: #adb5bd;
    }

    .empty-state i {
      font-size: 2.5rem;
      margin-bottom: 0.75rem;
    }
  </style>
</head>
<body>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">

      <!-- Request Form Card -->
      <div class="card mb-4">
        <div class="card-header text-white">
          <div class="d-flex align-items-center gap-2">
            <i class="bi bi-calendar2-plus fs-5"></i>
            <div>
              <h5 class="mb-0 fw-semibold">Day Off Request</h5>
              <small class="opacity-75">Submit a new time-off request</small>
            </div>
          </div>
        </div>

        <div class="card-body p-4">
          <form action="/dayoff" method="POST">

            <div class="row g-3 mb-3">
              <div class="col-12 col-sm-6">
                <label class="form-label fw-medium text-secondary small">
                  <i class="bi bi-calendar-event me-1"></i>From Date
                </label>
                <input type="date" name="fromDate" class="form-control" required />
              </div>
              <div class="col-12 col-sm-6">
                <label class="form-label fw-medium text-secondary small">
                  <i class="bi bi-calendar-event me-1"></i>To Date
                  <span class="text-muted">(optional)</span>
                </label>
                <input type="date" name="toDate" class="form-control" />
              </div>
            </div>

            <div class="mb-4">
              <label class="form-label fw-medium text-secondary small">
                <i class="bi bi-chat-left-text me-1"></i>Reason
                <span class="text-muted">(optional)</span>
              </label>
              <textarea
                name="reason"
                class="form-control"
                rows="3"
                placeholder="Briefly describe your reason..."
                style="resize: none;"
              ></textarea>
            </div>

            <div class="d-grid">
              <button type="submit" class="btn btn-primary btn-submit text-white">
                <i class="bi bi-send me-2"></i>Submit Request
              </button>
            </div>

          </form>
        </div>
      </div>

      <!-- Request History Card -->
      <div class="card history-card">
        <div class="card-header d-flex align-items-center justify-content-between">
          <div class="d-flex align-items-center gap-2">
            <i class="bi bi-clock-history text-primary"></i>
            <h6 class="mb-0 fw-semibold text-dark">My Requests</h6>
          </div>
          <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill">
            <%= requests.length %> total
          </span>
        </div>

        <div class="card-body p-0">
          <% if (requests.length === 0) { %>
            <div class="empty-state text-center">
              <div><i class="bi bi-inbox"></i></div>
              <p class="mb-0 small">No requests submitted yet</p>
            </div>
          <% } else { %>
            <div class="table-responsive">
              <table class="table mb-0">
                <thead>
                  <tr>
                    <th class="ps-4">From</th>
                    <th>To</th>
                    <th>Reason</th>
                    <th class="pe-4 text-end">Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% requests.forEach(r => { %>
                    <tr>
                      <td class="ps-4"><%= r.fromDate.toDateString() %></td>
                      <td><%= r.toDate.toDateString() %></td>
                      <td class="text-muted"><%= r.reason || "—" %></td>
                      <td class="pe-4 text-end">
                        <span class="status-badge
                          <% if (r.status === 'approved') { %>badge-approved
                          <% } else if (r.status === 'rejected') { %>badge-rejected
                          <% } else { %>badge-pending<% } %>">
                          <% if (r.status === 'approved') { %>
                            <i class="bi bi-check-circle-fill me-1"></i>
                          <% } else if (r.status === 'rejected') { %>
                            <i class="bi bi-x-circle-fill me-1"></i>
                          <% } else { %>
                            <i class="bi bi-hourglass-split me-1"></i>
                          <% } %>
                          <%= r.status.charAt(0).toUpperCase() + r.status.slice(1) %>
                        </span>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>

    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>