<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= typeof title !== 'undefined' ? title : "Guard Portal" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background-color: #f8f9fa;
        }

        main {
            flex: 1;
        }

        .card {
            border-radius: 12px;
        }

        .navbar-brand {
            font-weight: 600;
        }

        footer {
            background: #212529;
            color: white;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <%- include('partials/navbar') %>

    <!-- Main Content -->
    <main class="container py-5">
        <%- body %>
    </main>

    <!-- Footer -->
    <footer class="text-center py-3 mt-auto">
        <small>© <%= new Date().getFullYear() %> Guard Portal System | Workforce Management</small>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
