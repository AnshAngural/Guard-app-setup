<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>

<style>
  body { background: #f0f2f5; }
  .page-header {
    background: linear-gradient(135deg, #1a73e8, #0d47a1);
    border-radius: 16px;
    padding: 1.5rem 2rem;
    color: white;
    margin-bottom: 2rem;
  }
  .main-card {
    border: none;
    border-radius: 16px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
  }
  .table th {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: #6c757d;
    font-weight: 600;
    border-bottom: 2px solid #f0f2f5;
    padding: 1rem 1.25rem;
  }
  .table td {
    padding: 1rem 1.25rem;
    vertical-align: middle;
    font-size: 0.9rem;
    border-bottom: 1px solid #f8f9fa;
  }
  .table tbody tr:hover { background: #f8f9fb; }
  .avatar {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: #e8f0fe;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    color: #1a73e8;
    font-size: 0.85rem;
    flex-shrink: 0;
  }
  .btn-sm { border-radius: 8px; font-size: 0.8rem; }
</style>

<div class="container py-5">

  <div class="page-header d-flex align-items-center justify-content-between">
    <div>
      <h4 class="mb-1 fw-semibold">
        <i class="bi bi-shield-fill-check me-2"></i>Guards
      </h4>
      <small class="opacity-75"><%= guards.length %> registered accounts</small>
    </div>
    <a href="/admin" class="btn btn-light btn-sm">
      <i class="bi bi-arrow-left me-1"></i>Dashboard
    </a>
  </div>

  <div class="main-card card">
    <div class="card-body p-0">

      <% if (guards.length === 0) { %>
        <div class="text-center py-5 text-muted">
          <i class="bi bi-people fs-2 d-block mb-2"></i>
          <p class="mb-0">No guards registered yet</p>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th>Guard</th>
                <th>Email</th>
                <th>Joined</th>
                <th class="text-end pe-4">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% guards.forEach(g => { %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center gap-3">
                      <div class="avatar">
                        <%= g.name.charAt(0).toUpperCase() %>
                      </div>
                      <span class="fw-medium"><%= g.name %></span>
                    </div>
                  </td>
                  <td class="text-muted"><%= g.email %></td>
                  <td class="text-muted">
                    <%= new Date(g.createdAt).toDateString() %>
                  </td>
                  <td class="text-end pe-4">
                    <div class="d-flex gap-2 justify-content-end">
                      <a href="/admin/guards/<%= g._id %>"
                         class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-clock-history me-1"></i>Timecard
                      </a>
                      <form action="/admin/guards/<%= g._id %>/delete"
                            method="POST"
                            onsubmit="return confirm('Delete <%= g.name %>? This cannot be undone.')">
                        <button class="btn btn-sm btn-outline-danger">
                          <i class="bi bi-trash me-1"></i>Delete
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

    </div>
  </div>
</div>