<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>

<style>
  body { background: #f0f2f5; }

  .stat-card {
    border: none;
    border-radius: 16px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    transition: transform 0.15s;
  }
  .stat-card:hover { transform: translateY(-2px); }

  .stat-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
  }

  .stat-number {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
  }

  .nav-card {
    border: none;
    border-radius: 14px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s;
    display: block;
  }
  .nav-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 24px rgba(0,0,0,0.12);
  }

  .page-header {
    background: linear-gradient(135deg, #1a73e8, #0d47a1);
    border-radius: 16px;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
  }
</style>

<div class="container py-5">

  <!-- Header -->
  <div class="page-header d-flex align-items-center justify-content-between">
    <div>
      <h3 class="mb-1 fw-semibold">
        <i class="bi bi-speedometer2 me-2"></i>Admin Dashboard
      </h3>
      <small class="opacity-75">Guard Portal Management</small>
    </div>
    <div class="text-end">
      <small class="opacity-75">Logged in as</small>
      <div class="fw-semibold"><%= typeof user !== 'undefined' ? user.name : 'Admin' %></div>
    </div>
  </div>

  <!-- Stats -->
  <div class="row g-4 mb-5">

    <div class="col-12 col-sm-4">
      <div class="stat-card card p-4">
        <div class="d-flex align-items-center gap-3">
          <div class="stat-icon" style="background:#e8f0fe">
            <i class="bi bi-people-fill text-primary"></i>
          </div>
          <div>
            <div class="stat-number text-dark"><%= guards %></div>
            <div class="text-muted small">Total Guards</div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-sm-4">
      <div class="stat-card card p-4">
        <div class="d-flex align-items-center gap-3">
          <div class="stat-icon" style="background:#e6f4ea">
            <i class="bi bi-building-fill text-success"></i>
          </div>
          <div>
            <div class="stat-number text-dark"><%= sites %></div>
            <div class="text-muted small">Active Sites</div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-sm-4">
      <div class="stat-card card p-4">
        <div class="d-flex align-items-center gap-3">
          <div class="stat-icon" style="background:#fef3e2">
            <i class="bi bi-hourglass-split text-warning"></i>
          </div>
          <div>
            <div class="stat-number text-dark"><%= requests %></div>
            <div class="text-muted small">Pending Requests</div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Navigation Cards -->
  <h6 class="text-muted text-uppercase fw-semibold mb-3" style="letter-spacing:0.8px; font-size:0.75rem;">
    Management
  </h6>

  <div class="row g-4">

    <div class="col-12 col-sm-6 col-lg-3">
      <a href="/admin/guards" class="nav-card card p-4 text-dark">
        <div class="mb-3">
          <div class="stat-icon" style="background:#e8f0fe; width:44px; height:44px; font-size:1.2rem;">
            <i class="bi bi-shield-fill-check text-primary"></i>
          </div>
        </div>
        <div class="fw-semibold mb-1">Guards</div>
        <div class="text-muted small">View accounts, timecards & delete</div>
        <div class="mt-3 text-primary small fw-medium">
          Manage <i class="bi bi-arrow-right ms-1"></i>
        </div>
      </a>
    </div>

    <div class="col-12 col-sm-6 col-lg-3">
      <a href="/admin/sites" class="nav-card card p-4 text-dark">
        <div class="mb-3">
          <div class="stat-icon" style="background:#e6f4ea; width:44px; height:44px; font-size:1.2rem;">
            <i class="bi bi-building-fill text-success"></i>
          </div>
        </div>
        <div class="fw-semibold mb-1">Sites</div>
        <div class="text-muted small">Create, assign guards & delete</div>
        <div class="mt-3 text-success small fw-medium">
          Manage <i class="bi bi-arrow-right ms-1"></i>
        </div>
      </a>
    </div>

    <div class="col-12 col-sm-6 col-lg-3">
      <a href="/admin/requests" class="nav-card card p-4 text-dark">
        <div class="mb-3">
          <div class="stat-icon" style="background:#fef3e2; width:44px; height:44px; font-size:1.2rem;">
            <i class="bi bi-calendar2-check text-warning"></i>
          </div>
        </div>
        <div class="fw-semibold mb-1">Time Off</div>
        <div class="text-muted small">Review & approve requests</div>
        <div class="mt-3 text-warning small fw-medium">
          Manage <i class="bi bi-arrow-right ms-1"></i>
        </div>
      </a>
    </div>

    <div class="col-12 col-sm-6 col-lg-3">
      <a href="/logout" class="nav-card card p-4 text-dark">
        <div class="mb-3">
          <div class="stat-icon" style="background:#fce8e8; width:44px; height:44px; font-size:1.2rem;">
            <i class="bi bi-box-arrow-right text-danger"></i>
          </div>
        </div>
        <div class="fw-semibold mb-1">Logout</div>
        <div class="text-muted small">End your admin session</div>
        <div class="mt-3 text-danger small fw-medium">
          Sign out <i class="bi bi-arrow-right ms-1"></i>
        </div>
      </a>
    </div>

  </div>
</div>