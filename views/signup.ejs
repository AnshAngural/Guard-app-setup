<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>

<style>
  body { background: #f0f2f5; min-height: 100vh; }

  .auth-card {
    border: none;
    border-radius: 18px;
    box-shadow: 0 4px 32px rgba(0,0,0,0.10);
  }

  .auth-header {
    background: linear-gradient(135deg, #1a73e8, #0d47a1);
    border-radius: 18px 18px 0 0;
    padding: 2rem;
    text-align: center;
  }

  .form-control {
    border-radius: 10px;
    border: 1.5px solid #dee2e6;
    padding: 0.65rem 1rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-control:focus {
    border-color: #1a73e8;
    box-shadow: 0 0 0 3px rgba(26,115,232,0.15);
  }

  .form-control.is-invalid { border-color: #dc3545; box-shadow: none; }
  .form-control.is-valid   { border-color: #198754; box-shadow: none; }

  .btn-auth {
    background: linear-gradient(135deg, #1a73e8, #0d47a1);
    border: none;
    border-radius: 10px;
    padding: 0.75rem;
    font-weight: 500;
    transition: opacity 0.2s, transform 0.1s;
  }

  .btn-auth:hover:not(:disabled) { opacity: 0.9; transform: translateY(-1px); }
  .btn-auth:disabled { opacity: 0.7; cursor: not-allowed; }

  .password-wrapper { position: relative; }

  .toggle-pw {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    cursor: pointer;
    color: #6c757d;
    background: none;
    border: none;
    padding: 0;
  }

  .toggle-pw:hover { color: #1a73e8; }
  .input-feedback { font-size: 0.78rem; margin-top: 0.3rem; }

  .strength-bar {
    height: 4px;
    border-radius: 4px;
    transition: width 0.3s, background 0.3s;
    width: 0%;
  }

  .strength-wrap {
    background: #e9ecef;
    border-radius: 4px;
    height: 4px;
    margin-top: 6px;
    overflow: hidden;
  }
</style>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-sm-10 col-md-6 col-lg-5">

      <div class="auth-card card">

        <div class="auth-header text-white">
          <i class="bi bi-person-plus fs-2 mb-2 d-block"></i>
          <h4 class="mb-0 fw-semibold">Create account</h4>
          <small class="opacity-75">Join the Guard Portal</small>
        </div>

        <div class="card-body p-4">

          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger d-flex align-items-center gap-2 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
              <span class="small"><%= error %></span>
            </div>
          <% } %>

          <form method="POST" action="/signup" id="signupForm" novalidate>

            <!-- Name -->
            <div class="mb-3">
              <label class="form-label fw-medium text-secondary small">
                <i class="bi bi-person me-1"></i>Full name
              </label>
              <input
                type="text"
                name="name"
                id="nameInput"
                class="form-control"
                value="<%= typeof name !== 'undefined' ? name : '' %>"
                placeholder="John Smith"
                autocomplete="name"
                required
              />
              <div class="input-feedback text-danger d-none" id="nameError">
                Name must be at least 2 characters.
              </div>
            </div>

            <!-- Email -->
            <div class="mb-3">
              <label class="form-label fw-medium text-secondary small">
                <i class="bi bi-envelope me-1"></i>Email address
              </label>
              <input
                type="email"
                name="email"
                id="emailInput"
                class="form-control"
                value="<%= typeof email !== 'undefined' ? email : '' %>"
                placeholder="you@example.com"
                autocomplete="email"
                required
              />
              <div class="input-feedback text-danger d-none" id="emailError">
                Please enter a valid email address.
              </div>
            </div>

            <!-- Password -->
            <div class="mb-4">
              <label class="form-label fw-medium text-secondary small">
                <i class="bi bi-lock me-1"></i>Password
              </label>
              <div class="password-wrapper">
                <input
                  type="password"
                  name="password"
                  id="passwordInput"
                  class="form-control pe-5"
                  placeholder="Min. 6 characters"
                  autocomplete="new-password"
                  required
                />
                <button type="button" class="toggle-pw" id="togglePw" tabindex="-1">
                  <i class="bi bi-eye" id="togglePwIcon"></i>
                </button>
              </div>
              <div class="strength-wrap mt-2">
                <div class="strength-bar" id="strengthBar"></div>
              </div>
              <div class="input-feedback d-none" id="strengthLabel"></div>
              <div class="input-feedback text-danger d-none" id="passwordError">
                Password must be at least 6 characters.
              </div>
            </div>

            <div class="d-grid">
              <button type="submit" class="btn btn-auth btn-primary text-white" id="submitBtn">
                <span id="btnText">
                  <i class="bi bi-person-check me-2"></i>Create Account
                </span>
                <span id="btnSpinner" class="d-none">
                  <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                  Creating account...
                </span>
              </button>
            </div>

          </form>

          <div class="text-center mt-4">
            <small class="text-muted">
              Already have an account?
              <a href="/login" class="text-primary fw-medium text-decoration-none">Sign in</a>
            </small>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const form          = document.getElementById("signupForm");
  const nameInput     = document.getElementById("nameInput");
  const emailInput    = document.getElementById("emailInput");
  const passwordInput = document.getElementById("passwordInput");
  const nameError     = document.getElementById("nameError");
  const emailError    = document.getElementById("emailError");
  const passwordError = document.getElementById("passwordError");
  const submitBtn     = document.getElementById("submitBtn");
  const btnText       = document.getElementById("btnText");
  const btnSpinner    = document.getElementById("btnSpinner");
  const togglePw      = document.getElementById("togglePw");
  const togglePwIcon  = document.getElementById("togglePwIcon");
  const strengthBar   = document.getElementById("strengthBar");
  const strengthLabel = document.getElementById("strengthLabel");

  // Track whether user has interacted with each field
  let nameTouched     = false;
  let emailTouched    = false;
  let passwordTouched = false;

  // ── Show/hide password ──────────────────────────
  togglePw.addEventListener("click", () => {
    const isPassword = passwordInput.type === "password";
    passwordInput.type     = isPassword ? "text" : "password";
    togglePwIcon.className = isPassword ? "bi bi-eye-slash" : "bi bi-eye";
  });

  // ── Password strength ───────────────────────────
  passwordInput.addEventListener("input", () => {
    passwordTouched = true;
    const val = passwordInput.value;
    let score = 0;
    if (val.length >= 6)           score++;
    if (val.length >= 10)          score++;
    if (/[A-Z]/.test(val))         score++;
    if (/[0-9]/.test(val))         score++;
    if (/[^A-Za-z0-9]/.test(val))  score++;

    const levels = [
      { width: "20%",  color: "#dc3545", label: "Very weak",  cls: "text-danger"  },
      { width: "40%",  color: "#fd7e14", label: "Weak",       cls: "text-warning" },
      { width: "60%",  color: "#ffc107", label: "Fair",       cls: "text-warning" },
      { width: "80%",  color: "#20c997", label: "Good",       cls: "text-success" },
      { width: "100%", color: "#198754", label: "Strong",     cls: "text-success" },
    ];

    if (val.length === 0) {
      strengthBar.style.width = "0%";
      strengthLabel.classList.add("d-none");
      return;
    }

    const level = levels[Math.min(score - 1, 4)];
    strengthBar.style.width      = level.width;
    strengthBar.style.background = level.color;
    strengthLabel.textContent    = level.label;
    strengthLabel.className      = `input-feedback ${level.cls}`;

    passwordInput.classList.remove("is-invalid");
    passwordError.classList.add("d-none");
  });

  // ── Clear errors on input ───────────────────────
  nameInput.addEventListener("input", () => {
    nameTouched = true;
    nameInput.classList.remove("is-invalid");
    nameError.classList.add("d-none");
  });

  emailInput.addEventListener("input", () => {
    emailTouched = true;
    emailInput.classList.remove("is-invalid");
    emailError.classList.add("d-none");
  });

  // ── Blur validation — only if field was touched ─
  nameInput.addEventListener("blur", () => {
    if (nameTouched) validateName();
  });

  emailInput.addEventListener("blur", () => {
    if (emailTouched && emailInput.value.trim().length > 0) validateEmail();
  });

  passwordInput.addEventListener("blur", () => {
    if (passwordTouched && passwordInput.value.length > 0) validatePassword();
  });

  // ── Validators ──────────────────────────────────
  function validateName() {
    const val   = nameInput.value.trim();
    const valid = val.length >= 2;
    nameInput.classList.toggle("is-invalid", !valid);
    nameInput.classList.toggle("is-valid",    valid);
    nameError.classList.toggle("d-none",      valid);
    return valid;
  }

  function validateEmail() {
    const val   = emailInput.value.trim();
    const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
    emailInput.classList.toggle("is-invalid", !valid);
    emailInput.classList.toggle("is-valid",    valid);
    emailError.classList.toggle("d-none",      valid);
    return valid;
  }

  function validatePassword() {
    const val   = passwordInput.value;
    const valid = val.length >= 6;
    passwordInput.classList.toggle("is-invalid", !valid);
    passwordInput.classList.toggle("is-valid",    valid);
    passwordError.classList.toggle("d-none",      valid);
    return valid;
  }

  // ── Submit ──────────────────────────────────────
  form.addEventListener("submit", (e) => {
    // Force validate all fields on submit regardless of touch state
    const nameOk     = validateName();
    const emailOk    = validateEmail();
    const passwordOk = validatePassword();

    if (!nameOk || !emailOk || !passwordOk) {
      e.preventDefault();
      return;
    }

    submitBtn.disabled = true;
    btnText.classList.add("d-none");
    btnSpinner.classList.remove("d-none");
  });
</script>